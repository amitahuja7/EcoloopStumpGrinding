# Core server settings
PORT=3003
BASE_URL=https://www.ecoloopstumpgrinding.com.au

# Email notifications (used for admin alerts + customer acknowledgement)
ADMIN_EMAIL=sales@ecoloopstumpgrinding.com.au
EMAIL_USER=your_gmail_or_smtp_user_here
EMAIL_PASSWORD=your_email_app_password_here

# Optional SMS notifications
ADMIN_PHONE=+614xxxxxxxx
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google Sheets webhook integration
ENABLE_SHEETS_SYNC=true
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your_script_id/exec
